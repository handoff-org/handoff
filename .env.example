# handoff — optional environment variables
#
# handoff is local-first and needs NO configuration to run. Every variable below
# is OPTIONAL. There is no dotenv loader — handoff reads these from the process
# environment, so `export` them in your shell (or your launcher) rather than
# relying on this file being auto-loaded. Copy to `.env` only if your own shell
# setup sources it.
#
# Most settings also live in the interactive config (/settings, /model); env
# vars override the stored config for that session.

# ── Model backend ───────────────────────────────────────────────────────────
# Which local backend to use: ollama | llama_cpp | mlx | huggingface
HANDOFF_BACKEND=
# Default model id (e.g. an Ollama tag like "gemma3:4b")
HANDOFF_MODEL=
# Base URLs for OpenAI-compatible local servers (override defaults/ports)
HANDOFF_LLAMACPP_URL=
HANDOFF_MLX_URL=
HANDOFF_VLLM_URL=
# Ollama tuning
HANDOFF_OLLAMA_NUM_CTX=
HANDOFF_OLLAMA_KEEP_ALIVE=
OLLAMA_MODELS=
# Generation cap
HANDOFF_MAX_TOKENS=

# ── Cloud (opt-in only) ──────────────────────────────────────────────────────
# HuggingFace Inference token — ONLY needed if you opt into a cloud model.
HF_TOKEN=

# ── Research connectors (optional) ───────────────────────────────────────────
HANDOFF_ZOTERO_API_KEY=
HANDOFF_ZOTERO_USER_ID=
HANDOFF_OPENREVIEW_USERNAME=
HANDOFF_OPENREVIEW_PASSWORD=

# ── UI / behavior ────────────────────────────────────────────────────────────
HANDOFF_MODE=            # hands-on | hands-off
HANDOFF_THEME=
HANDOFF_REDUCED_MOTION=  # 1 = hold the mascot still
HANDOFF_NO_ANIM=         # 1 = disable animations
NO_COLOR=                # 1 = monochrome (respected app-wide)

# ── Editor (for /compose-skill etc.) ─────────────────────────────────────────
EDITOR=
VISUAL=
