# Dependencies
node_modules/

# Build output (handoff runs from source via tsx; dist/ is only for publishing)
dist/

# Jekyll / GitHub Pages local build artifacts (the docs/ site builds server-side)
docs/_site/
docs/.jekyll-cache/
docs/.jekyll-metadata
docs/Gemfile.lock

# OS / editor cruft
.DS_Store
*.log
BUILD_SEQUENCE.txt
PRODUCT_PLAN.txt
TODO.md
ERRORS.md

# QA chat-simulation harness output + isolated temp HOMEs
qa/logs/
qa/reports/
tmp/

# Eval framework: the tool stays tracked (scenarios, fixtures, schema, runners,
# scorers, reporters, README/AUTHORING). Generated artifacts and internal reports
# are NOT shipped — per-run reports, promoted baselines, and the baseline audit are
# regenerated locally (npm run eval:*).
evals/reports/
evals/baselines/
evals/BASELINE_AUDIT.md
tmp_*.ts

# Benchmark adapters: downloaded datasets, run outputs, and per-run scratch
# (capsules, task work dirs). The adapter code (src/adapters/) and the
# comparison script (benchmarks/scripts/) stay tracked.
benchmarks/data/
benchmarks/results/
benchmarks/work/
benchmarks/latest.md

# Generated audit/report docs (internal records, not shipped)
docs/product-audit.md

# Debug pass logs
debug/logs/
docs/landing.html

# Local GPU/CPU inference profiling scripts + their outputs (dev tooling, not shipped)
profiling/
